# ---------------------------------------------------------------------------
# Client-side (bundled into the browser build — anything VITE_ prefixed is
# PUBLIC). Never put the service role key or the admin password here.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Server-side only (Supabase Edge Function secrets + Vercel env vars).
# These must NEVER be VITE_ prefixed and never referenced from src/.
# ---------------------------------------------------------------------------

# Supabase > Project Settings > API > service_role. Bypasses RLS. Secret.
SUPABASE_SERVICE_ROLE_KEY=

# Resend > API Keys
RESEND_API_KEY=

# Verified sender in Resend, e.g. teams@yourcompdomain.com
FROM_EMAIL=

# Single shared password for /admin. Checked in an Edge Function only.
ADMIN_PASSWORD=

# Event slug written to listings.event_id
EVENT_ID=iron-games-2026

# Origin used to build confirm/manage links in emails. No trailing slash.
PUBLIC_BASE_URL=https://teammate-finder.vercel.app
